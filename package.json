{
  "name": "swiggy-auto-restock-agent",
  "version": "2.0.0",
  "description": "AI-powered household grocery restock agent on Swiggy Instamart MCP — powered by Google Gemini",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "seed": "node scripts/seed.js",
