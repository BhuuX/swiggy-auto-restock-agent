# ── Google Gemini ──────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Swiggy MCP ─────────────────────────────────────────
# You'll get these once Swiggy approves your application
SWIGGY_CLIENT_ID=your_client_id
SWIGGY_CLIENT_SECRET=your_client_secret
SWIGGY_REDIRECT_URI=http://localhost:3000/callback
SWIGGY_MCP_BASE_URL=https://mcp.swiggy.com

# ── App ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Mock Mode ─────────────────────────────────────────
# Set to "true" while waiting for Swiggy API approval
# Set to "false" once you have real credentials
USE_MOCK_SWIGGY=true
